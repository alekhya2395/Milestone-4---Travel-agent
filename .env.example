# Brain 1 — Groq (parser, research, accommodation, transport, composer)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Groq rate limits — llama-3.3-70b-versatile (RPM / RPD / TPM / TPD)
GROQ_RPM=30
GROQ_RPD=1000
GROQ_TPM=12000
GROQ_TPD=100000
GROQ_MAX_TOKENS=4096

# Brain 2 — Gemini (budget, validator)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Gemini 3 Flash rate limits (RPM / TPM / RPD)
GEMINI_RPM=5
GEMINI_TPM=250000
GEMINI_RPD=20
GEMINI_MAX_TOKENS=4096

# Data source — "llm" only today; "web_search" / "apis" reserved for future phases
DATA_SOURCE=llm

# Orchestration — keep retries low on free tier (each retry = more API calls)
MAX_VALIDATION_RETRIES=1
AGENT_TIMEOUT_S=60
JSON_REPAIR_RETRIES=1
AGENT_API_RETRIES=1
AGENT_RETRY_BACKOFF_S=1.0
RATE_LIMIT_ENABLED=true
GATHER_PARALLEL=true
